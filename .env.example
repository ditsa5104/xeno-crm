# Django
SECRET_KEY=change-me-in-production
DEBUG=True
DATABASE_URL=postgresql://xeno:xeno@db:5432/xeno_crm
REDIS_URL=redis://redis:6379/0
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0,crm
SITE_URL=http://localhost:8000
CORS_ALLOWED_ORIGINS=http://localhost:5173
# Comma-separated, required in production (e.g. https://yourdomain.com)
CSRF_TRUSTED_ORIGINS=
# Optional: explicit base URL advertised in the Swagger/OpenAPI "Servers" list.
# Leave blank to auto-detect from the request (works for local + Render).
API_SERVER_URL=
DJANGO_SETTINGS_MODULE=config.settings.local

# AI
OPENROUTER_API_KEY=sk-or-v1-your-key-here
OPENROUTER_MODEL=anthropic/claude-sonnet-4-5

# Channel stub (shared HMAC secret)
CHANNEL_STUB_URL=http://channel_stub:8001
CHANNEL_STUB_SECRET=super-secret-change-me

# Channel stub callback target
CRM_WEBHOOK_URL=http://crm:8000/api/v1/webhooks/channel-event/
